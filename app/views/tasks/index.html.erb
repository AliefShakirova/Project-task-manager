<h1 class="text-center mb-4">📋 My tasks</h1>
<div class="text-center mb-3">
  <%= link_to "Add task", new_task_path, class: "btn btn-success" %>
</div>

<div class="row">
  <% @tasks.each do |task| %>
    <div class="col-md-4">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h5 class="card-title"><%= task.title %></h5>
          <p class="card-text"><%= task.description %></p>
          <span class="badge bg-<%= task.status == 'completed' ? 'success' : 'warning' %>">
            <%= task.status.humanize %>
          </span>
          <div class="mt-3">
            <%= link_to "✏️ Edit", edit_task_path(task), class: "btn btn-primary btn-sm" %>
            <%= link_to "🗑 Delete", task, method: :delete, data: { confirm: "Delete task?" }, class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

